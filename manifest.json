{
  "manifest_version": 3,
  "name": "Comfort Viewer - Watch scary videos comfortably",
  "version": "1.1.0",
  "description": "Place cute animals around horror/thriller videos for visual comfort.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-comfort": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Toggle Comfort Mode"
    }
  },
  "web_accessible_resources": [{
    "resources": ["images/*"],
    "matches": ["*://*.youtube.com/*", "*://*.netflix.com/*", "*://*.disneyplus.com/*"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content-youtube.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content-netflix.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.disneyplus.com/*"],
      "js": ["content-disney.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
